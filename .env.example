# ============================================
# Bastusastra - Environment Configuration
# ============================================

# PostgreSQL Configuration
POSTGRES_USER=bastusastra
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=bastusastra
DATABASE_URL="postgresql://bastusastra:your_secure_password_here@localhost:5432/bastusastra?schema=public"

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend Configuration
PORT=3001
NODE_ENV=development

# Optional: External APIs
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# SWISS_EPHEMERIS_PATH=/path/to/swiss/ephemeris
